{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "velo",
            "request": "launch",
            "type": "dart",
            "toolArgs": [
                "--dart-define-from-file",
                "config/config.json"
            ]
        },
        {
            "name": "velo (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile",
            "toolArgs": [
                "--dart-define-from-file",
                "config/config.json"
            ]
        },
        {
            "name": "velo (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "toolArgs": [
                "--dart-define-from-file",
                "config/config.json"
            ]
        },
        {
            "name": "velo (Web mode)",
            "request": "launch",
            "type": "dart",
            "args": [
                "-d",
                "chrome"
            ],
            "toolArgs": [
                "--dart-define-from-file",
                "config/config.json"
            ]
        }
    ]
}